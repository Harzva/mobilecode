    "non_counted_run_required_fields": [
      "run_kind",
      "counts_as_experiment",
      "counts_as_strategy_ablation_result",
      "evidence_boundary",
      "results",
      "summary"
    ],
    "android_webview_upgrade_assertions": [
      "ui_xml",
      "screenshot",
      "logcat",
      "webview_state",
      "focus_state",
      "accessibility_state"
    ]
  },
  "next_android_real_device_lane_recommendation": {
