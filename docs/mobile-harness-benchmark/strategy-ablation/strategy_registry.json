{
  "schema_version": "0.1.0",
  "benchmark": "MobileHarnessBench",
  "registry_id": "mobile-harness-strategy-registry-r1",
  "notes": "R1 strategies are scaffold definitions. They are not measured results.",
  "strategies": [
    {
      "strategy_id": "react_single_agent",
      "strategy_family": "single_agent_reasoning",
      "description": "One agent alternates think, act, and observe until completion or block.",
      "agent_roles": ["SingleAgent"],
      "reasoning_loop": ["think", "act", "observe", "report"],
      "allowed_tools": ["read_file", "apply_patch", "webview_preview", "evidence_record"],
      "max_steps": 12,
      "max_handoffs": 0,
      "verification_policy": "final_status_only",
      "memory_policy": "read_harness_memory_packet_once",
      "handoff_policy": "disabled",
      "expected_overhead": "low",
      "primary_comparison_targets": ["plan_execute_verify_single_agent", "react_with_final_verifier"]
    },
    {
      "strategy_id": "plan_execute_verify_single_agent",
      "strategy_family": "single_agent_reasoning",
      "description": "One agent creates a short plan, executes a step, verifies it, and retries or replans as needed.",
      "agent_roles": ["PlannerExecutorVerifier"],
      "reasoning_loop": ["plan", "execute", "verify", "retry_or_continue", "report"],
      "allowed_tools": ["read_file", "apply_patch", "webview_preview", "runtime_check", "evidence_record"],
      "max_steps": 16,
      "max_handoffs": 0,
      "verification_policy": "step_verification_required",
      "memory_policy": "read_harness_memory_packet_and_append_trace",
      "handoff_policy": "disabled",
      "expected_overhead": "medium",
      "primary_comparison_targets": ["react_single_agent", "supervisor_handoff_multi_agent"]
    },
    {
      "strategy_id": "react_with_final_verifier",
      "strategy_family": "single_agent_with_verifier",
      "description": "A ReAct actor completes the task and a separate verifier checks the final artifact and trace.",
      "agent_roles": ["ReActActor", "VerifierAgent"],
      "reasoning_loop": ["think", "act", "observe", "final_verify", "report"],
      "allowed_tools": ["read_file", "apply_patch", "webview_preview", "runtime_check", "evidence_record"],
      "max_steps": 14,
      "max_handoffs": 1,
      "verification_policy": "final_verifier_required",
      "memory_policy": "actor_gets_packet_verifier_gets_trace_summary",
      "handoff_policy": "verifier_summary_only",
      "expected_overhead": "medium",
      "primary_comparison_targets": ["react_single_agent", "plan_execute_verify_single_agent"]
    },
    {
      "strategy_id": "supervisor_handoff_multi_agent",
      "strategy_family": "multi_agent_handoff",
      "description": "A Supervisor plans and delegates typed HandoffPacket work to specialist mobile coding roles.",
      "agent_roles": ["Supervisor", "CodeAgent", "RuntimeAgent", "PreviewAgent", "VerifierAgent", "MemoryAgent", "ReporterAgent"],
      "reasoning_loop": ["supervisor_plan", "handoff", "specialist_react", "step_verify", "report", "memory_commit_proposal"],
      "allowed_tools": ["read_file", "apply_patch", "webview_preview", "runtime_check", "github_delivery", "evidence_record"],
      "max_steps": 20,
      "max_handoffs": 8,
      "verification_policy": "step_and_final_verification_required",
      "memory_policy": "role_filtered_harness_memory_packets",
      "handoff_policy": "structured_packet_with_input_filter",
      "expected_overhead": "high",
      "primary_comparison_targets": ["plan_execute_verify_single_agent", "swarm_router_multi_agent"]
    },
    {
      "strategy_id": "swarm_router_multi_agent",
      "strategy_family": "multi_agent_swarm",
      "description": "A router selects the best specialist swarm by task category, device/runtime profile, and load.",
      "agent_roles": ["SwarmRouter", "CodeSwarm", "RuntimeSwarm", "PreviewSwarm", "JudgeAgent"],
      "reasoning_loop": ["route", "swarm_execute", "judge", "gap_fill", "report"],
      "allowed_tools": ["read_file", "apply_patch", "webview_preview", "runtime_check", "evidence_record"],
      "max_steps": 24,
      "max_handoffs": 12,
      "verification_policy": "judge_required",
      "memory_policy": "task_packet_plus_swarm_local_trace",
      "handoff_policy": "router_filtered",
      "expected_overhead": "very_high",
      "primary_comparison_targets": ["supervisor_handoff_multi_agent", "hierarchical_swarm_multi_agent"]
    },
    {
      "strategy_id": "hierarchical_swarm_multi_agent",
      "strategy_family": "multi_agent_swarm",
      "description": "A manager decomposes the task and delegates to workers, then reconciles judged outputs.",
      "agent_roles": ["ManagerAgent", "WorkerAgents", "JudgeAgent", "ReporterAgent"],
      "reasoning_loop": ["manager_plan", "worker_execute", "judge", "manager_reconcile", "report"],
      "allowed_tools": ["read_file", "apply_patch", "webview_preview", "runtime_check", "github_delivery", "evidence_record"],
      "max_steps": 28,
      "max_handoffs": 16,
      "verification_policy": "judge_and_manager_reconciliation_required",
      "memory_policy": "manager_packet_worker_filtered_subtasks",
