<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- 
      PROFILE build only - performance profiling
      This file is ONLY used in profile builds (flutter run --profile)
      
      Profile builds are INTERMEDIATE between debug and release:
      - Optimized code (not debuggable)
      - But with profiling data collection
      - NO cleartext traffic allowed
      - Debuggable is FALSE (like release)
    -->
    
    <!-- Profile: No cleartext, same security as release -->
    <application 
        android:usesCleartextTraffic="false"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:replace="android:usesCleartextTraffic,android:networkSecurityConfig">
    </application>
    
    <uses-permission android:name="android.permission.INTERNET"/>
</manifest>
